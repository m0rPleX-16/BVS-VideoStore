
@model List<BVS.Models.CustomerRentalsViewModel>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="m-0">Customer Rentals Report</h2>
    <button type="button" class="btn btn-outline-primary" onclick="window.print()">Print</button>
</div>

<div class="mb-3">
    <strong>Total customers:</strong> @Model.Count
</div>

    <div class="mb-3">
    <a class="btn btn-outline-primary me-2" asp-controller="Rental" asp-action="CustomerRentalsReportCsv">Export CSV</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Customer</th>
                <th>Current Rentals</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.CustomerName</td>
                <td>
                    @if (c.CurrentRentals.Any())
                    {
                        <ul class="mb-0">
                        @foreach (var title in c.CurrentRentals)
                        {
                            <li>@title</li>
                        }
                        </ul>
                    }
                    else
                    {
                        <em>No current rentals</em>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
