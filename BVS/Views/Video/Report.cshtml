@model List<Video>
@{
    ViewData["Title"] = "Video Report";
    var totalIn = Model.Sum(v => v.AvailableQuantity);
    var totalOut = Model.Sum(v => Math.Max(0, v.TotalQuantity - v.AvailableQuantity));
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="m-0 fw-bold"><i class="bi bi-bar-chart-fill me-2"></i>Video Report</h2>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" asp-controller="Video" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Back to Videos</a>
        <a class="btn btn-outline-success btn-sm" asp-controller="Rental" asp-action="VideosReportCsv"><i class="bi bi-download me-1"></i>Export CSV</a>
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="window.print()"><i class="bi bi-printer me-1"></i>Print</button>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-auto">
        <div class="card px-4 py-3 text-center">
            <div class="fs-4 fw-bold text-primary">@Model.Count</div>
            <div class="small text-muted">Titles</div>
        </div>
    </div>
    <div class="col-auto">
        <div class="card px-4 py-3 text-center">
            <div class="fs-4 fw-bold text-success">@totalIn</div>
            <div class="small text-muted">In Stock</div>
        </div>
    </div>
    <div class="col-auto">
        <div class="card px-4 py-3 text-center">
            <div class="fs-4 fw-bold text-warning">@totalOut</div>
            <div class="small text-muted">Rented Out</div>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Category</th>
                <th class="text-end">In</th>
                <th class="text-end">Out</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var v in Model)
        {
            var outCount = Math.Max(0, v.TotalQuantity - v.AvailableQuantity);
            <tr>
                <td>@v.Title</td>
                <td><span class="badge @(v.Category.ToString() == "DVD" ? "bg-primary" : "bg-warning text-dark")">@v.Category</span></td>
                <td class="text-end">@v.AvailableQuantity</td>
                <td class="text-end @(outCount > 0 ? "text-warning fw-semibold" : "")">@outCount</td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="4" class="text-center text-muted py-4">No videos found.</td></tr>
        }
        </tbody>
    </table>
</div>
